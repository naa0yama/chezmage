# .chezmoi.toml.tmpl
#
# chezmage configuration template for chezmoi
# identity serves as both: shim's -i flag trigger and wrapper's key path

encryption = "age"

[age]
{{- if eq .chezmoi.os "linux" }}
  command = "{{ .chezmoi.homeDir }}/.local/bin/chezmage"
{{- else if eq .chezmoi.os "windows" }}
  command = '{{ .chezmoi.homeDir }}\.local\bin\chezmage.exe'
{{- end }}
  args = ["--shim"]
  # Single key:
  # identity = "{{ .chezmoi.homeDir }}/.config/chezmoi/age-key.gpg"

  # Multiple keys:
  identities = [
    "{{ .chezmoi.homeDir }}/.config/chezmoi/personal.gpg",
    "{{ .chezmoi.homeDir }}/.config/chezmoi/work.gpg",
  ]

  recipient = "age1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  # recipients = ["age1...", "age1..."]
